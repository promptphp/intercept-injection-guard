{
    "name": "promptphp/intercept-injection-guard",
    "description": "Prompt injection guard middleware for Laravel AI agents.",
    "keywords": ["laravel", "ai", "middleware", "prompt", "prompt-injection", "security"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4.0",
        "laravel/ai": "^0.8.0",
        "promptphp/intercept-support": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "PromptPHP\\Intercept\\InjectionGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PromptPHP\\Intercept\\InjectionGuard\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}